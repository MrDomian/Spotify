# Spotify Developer Dashboard credentials
# https://developer.spotify.com/dashboard
NEXT_PUBLIC_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# NextAuth (JWT_SECRET or NEXTAUTH_SECRET — at least one required)
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=generate_a_random_secret_string

# Redirect URI to add in Spotify Dashboard:
# http://localhost:3000/api/auth/callback/spotify
